        const toggleTextSpan = document.getElementById('toggleText');
        const iconSpan = document.querySelector('#darkModeToggle .toggle-icon');
        
        // check local storage for preference
        const isDarkStored = localStorage.getItem('ratibaTheme') === 'dark';
        if (isDarkStored) {
            document.body.classList.add('dark');
            if (toggleTextSpan) toggleTextSpan.innerText = 'Light Mode';
            if (iconSpan) iconSpan.innerHTML = '☀️';
        } else {
            if (toggleTextSpan) toggleTextSpan.innerText = 'Dark Mode';
            if (iconSpan) iconSpan.innerHTML = '🌙';
        }
        
        toggleBtn.addEventListener('click', () => {
            const isDark = document.body.classList.toggle('dark');
            if (isDark) {
                localStorage.setItem('ratibaTheme', 'dark');
                if (toggleTextSpan) toggleTextSpan.innerText = 'Light Mode';
                if (iconSpan) iconSpan.innerHTML = '☀️';
            } else {
                localStorage.setItem('ratibaTheme', 'light');
                if (toggleTextSpan) toggleTextSpan.innerText = 'Dark Mode';
                if (iconSpan) iconSpan.innerHTML = '🌙';
            }
        });
    })();
</script>
